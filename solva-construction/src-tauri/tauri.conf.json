{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Construction Planner Desktop",
  "version": "1.0.2",
  "identifier": "com.teknabu.constructionplannerdesktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Construction Planner Desktop",
        "width": 1280,
        "height": 900,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENDNTlERDc1MUFCMEU3NzYKUldSMjU3QWFkZDFaek9Ma0d2ZFo3Y3dvcFJNeEtnYVozbVVIYlFwMG5ITmNkNXY3bGI3U1dya1EK",
      "endpoints": [
        "https://updates.solva.app/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
