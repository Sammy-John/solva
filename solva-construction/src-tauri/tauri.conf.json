{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Construction Planner Desktop",
  "version": "1.0.0",
  "identifier": "com.teknabu.constructionplannerdesktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Construction Planner Desktop",
        "width": 1280,
        "height": 900,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ]
  }
}
