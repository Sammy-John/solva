{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Construction Planner Desktop",
  "version": "1.1.1",
  "identifier": "com.teknabu.constructionplannerdesktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Construction Planner Desktop",
        "width": 1280,
        "height": 900,
        "resizable": true,
        "maximized": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERGQUU1NThBNzUyMkY5NTIKUldSUytTSjFpbFd1M3dJVDYvN3NPRXNHcWw5U0QzU0g2eW9mWTQ5cTlOQm45Mitzc2tjeGFQMWMK",
      "endpoints": [
        "https://github.com/Sammy-John/solva/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
