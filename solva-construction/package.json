{
  "name": "construction-planner-desktop",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run",
    "release:version:check": "node scripts/release/sync-version.mjs --check",
    "release:version:sync": "node scripts/release/sync-version.mjs --write",
    "release:alpha": "pwsh -NoProfile -File scripts/release/build-alpha.ps1",
    "release:manifest": "node scripts/release/publish-manifest.mjs",
    "release:alpha:test": "pwsh -NoProfile -File scripts/release/build-alpha-test.ps1",
    "release:manifest:test": "node scripts/release/publish-manifest.mjs --artifacts-root artifacts/test --latest-manifest artifacts/test/latest.json --installer-pattern \"Construction Planner Desktop Test\"",
    "release:manifest:github": "node scripts/release/publish-manifest.mjs --base-url https://github.com/Sammy-John/solva/releases/latest/download --omit-version-dir true --url-filename-mode github-dot",
    "release:manifest:test:github": "node scripts/release/publish-manifest.mjs --artifacts-root artifacts/test --latest-manifest artifacts/test/test-latest.json --installer-pattern \"Construction Planner Desktop Test\" --base-url https://github.com/Sammy-John/solva/releases/latest/download --omit-version-dir true --url-filename-mode github-dot"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-table": "^8.21.3",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0",
    "vitest": "^4.1.2"
  }
}
